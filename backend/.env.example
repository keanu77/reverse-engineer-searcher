# ======================
# LLM Provider 設定
# ======================
# 可選: groq (預設/免費), openai, grok, gemini, ollama, custom
LLM_PROVIDER=groq

# Groq API Key (免費，推薦使用)
# 申請地址: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI API Key
# 申請地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Grok (xAI) API Key
# 申請地址: https://console.x.ai/
XAI_API_KEY=

# Google Gemini API Key
# 申請地址: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 自訂 OpenAI 相容 API (進階設定)
# 可用於 Azure OpenAI, Together AI, Anyscale 等
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=

# ======================
# PubMed API 設定
# ======================
# PubMed API Key (可選，用於提高 rate limit)
# 申請地址: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# ======================
# Server 設定
# ======================
PORT=3001
